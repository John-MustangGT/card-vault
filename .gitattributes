# Normalize line endings to LF in the repository.
# This ensures sqlx migration checksums are consistent across Windows and Linux.

* text=auto

# Always LF — sqlx computes checksums from raw file bytes
*.sql       text eol=lf

# Always LF — Python scripts
*.py        text eol=lf

# Always LF — shell scripts
*.sh        text eol=lf

# Windows batch files must keep CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Binaries — no line ending conversion
*.db        binary
*.jpg       binary
*.jpeg      binary
*.png       binary
*.gif       binary
*.ico       binary
*.gz        binary
