# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite file. Use an absolute path in production.
DATABASE_URL=sqlite:./card-vault.db

# ── Storage ───────────────────────────────────────────────────────────────────
# Directory for front/back card scan images.
SCAN_STORAGE_PATH=./scans

# Directory containing all-cards-*.json.gz files downloaded from Scryfall.
DATA_DIR=./data

# ── Network ───────────────────────────────────────────────────────────────────
# Who can reach the server:
#   localhost  →  127.0.0.1   this machine only (safe default)
#   localnet   →  0.0.0.0     any machine on your LAN
#   any        →  0.0.0.0     open to all networks (pair with a firewall rule)
#   <ip>       →  that exact interface
HOST=localhost
PORT=3000
